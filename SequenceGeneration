#include <iostream>
using namespace std;


//1, -1, 2, -2...

int main(){
    int n;
    cin>>n;
    int odd=1,even=-1;
    for(int i=1;i<=n;i++){
        if(i%2==0){
            cout<<even<<" ";
            even--;
        }
        else{
            cout<<odd<<" ";
            odd++;
        }
    }
    
    return 0;
}
