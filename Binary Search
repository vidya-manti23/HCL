int binarySearch(vector<int>& arr, int target) {
    int low = 0;
    int high = arr.size() - 1;

    while (low <= high) {
        int mid = low + (high - low) / 2;

        if (arr[mid] == target) {
            return mid; // found
        }
        else if (arr[mid] < target) {
            low = mid + 1; // right side
        }
        else {
            high = mid - 1; // left side
        }
    }

    return -1; // not found
}
